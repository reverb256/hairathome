{
  "type": "module",
  "name": "hairathome",
  "version": "1.0.0",
  "description": "Hair@Home - Mobile hair stylist in Winnipeg",
  "scripts": {
    "build:css": "npx postcss ./input.css -o ./static/css/main.css --minify",
    "build": "npm run build:css && hugo --minify",
    "build:full": "npm run build:css && hugo --minify && bash scripts/optimize-images.sh",
    "optimize": "bash scripts/optimize-images.sh",
    "serve": "hugo server -D --bind 0.0.0.0",
    "dev": "npm run build:css && hugo server -D --bind 0.0.0.0 --disableFastRender",
    "nix:dev": "bash scripts/nix-dev-shell.sh",
    "astro:dev": "astro dev",
    "astro:build": "astro build",
    "astro:preview": "astro preview",
    "astro": "astro",
    "test": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/tailwind": "^6.0.0",
    "@biomejs/biome": "^2.3.14",
    "@playwright/test": "^1.48.0",
    "astro": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vscode-langservers-extracted": "^4.10.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@playwright/test": "^1.58.2",
    "astro-icon": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
