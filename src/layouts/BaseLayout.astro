---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Hair@Home' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-brand-cream text-brand-charcoal font-body dark:bg-brand-charcoal dark:text-brand-cream">
    <slot />
  </body>
</html>
