---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'faq');
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-medium text-brand-charcoal dark:text-brand-cream">
          Frequently Asked Questions
        </h1>
      </div>
      <article class="prose prose-zinc dark:prose-invert prose-lg mx-auto">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>
